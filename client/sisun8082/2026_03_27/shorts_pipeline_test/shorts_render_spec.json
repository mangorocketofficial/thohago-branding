  "text_overlays": [
    {
      "text_id": "t01",
      "kind": "hook",
      "text": "필리핀 손님 5명이\n한국 오기 전부터 예약",
      "start_sec": 0.2,
      "end_sec": 2.6,
      "position": "center",
      "style_preset": "hook_bold",
      "animation_in": "fade_up",
      "animation_out": "fade_out"
    },
    {
      "text_id": "t02",
      "kind": "supporting",
      "text": "두피 진단 후 맞춤 코스 추천",
      "start_sec": 3.2,
      "end_sec": 5.0,
      "position": "bottom_center",
      "style_preset": "label_minimal",
      "animation_in": "fade_in",
      "animation_out": "fade_out"
    },
    {
      "text_id": "t03",
      "kind": "supporting",
      "text": "스팀캡 → 캔들 케어 → LED",
      "start_sec": 7.7,
      "end_sec": 10.5,
      "position": "bottom_center",
      "style_preset": "label_minimal",
      "animation_in": "fade_in",
      "animation_out": "fade_out"
    },
    {
      "text_id": "t04",
      "kind": "quote",
      "text": "\"K-뷰티는 최고다\"",
      "start_sec": 14.5,
      "end_sec": 17.0,
      "position": "center",
      "style_preset": "quote_soft",
      "animation_in": "fade_up",
      "animation_out": "fade_out"
    },
    {
      "text_id": "t05",
      "kind": "quote",
      "text": "\"너무 시원하고 만족했다\"",
      "start_sec": 18.0,
      "end_sec": 19.8,
      "position": "center",
      "style_preset": "quote_soft",
      "animation_in": "fade_up",
      "animation_out": "fade_out"
    },
    {
      "text_id": "t06",
      "kind": "cta",
      "text": "시선을 즐기다",
      "start_sec": 20.5,
      "end_sec": 22.5,
      "position": "center",
      "style_preset": "cta_clean",
      "animation_in": "fade_in",
      "animation_out": "fade_out"
    },
    {
      "text_id": "t07",
      "kind": "cta",
      "text": "서면 헤드스파",
      "start_sec": 23.2,
      "end_sec": 23.8,
      "position": "bottom_center",
      "style_preset": "label_minimal",
      "animation_in": "fade_in",
      "animation_out": "fade_out"
    }
  ],
  "voiceover": {
    "mode": "tts",
    "script_blocks": [
      {
        "beat_id": "b01",
        "text": "필리핀에서 온 다섯 분이 한국 오기 전부터 예약하고 찾아온 서면 헤드스파.",
        "start_sec": 0.0,
        "end_sec": 3.0,
        "tone": "curious_warm"
      },
      {
        "beat_id": "b02",
        "text": "도착하자마자 두피 진단을 받고, 맞춤 코스를 추천받습니다.",
        "start_sec": 3.0,
        "end_sec": 7.5,
        "tone": "calm_informative"
      },
      {
        "beat_id": "b03",
        "text": "다섯 명이 함께 케어를 시작합니다. 캔들 향이 퍼지는 동안 두피 집중 케어, 이어서 LED 테라피.",
        "start_sec": 7.5,
        "end_sec": 14.0,
        "tone": "immersive"
      },
      {
        "beat_id": "b04",
        "text": "K-뷰티 최고라는 말을 연발하시고, 다들 너무 시원하다, 만족했다고 하시죠.",
        "start_sec": 14.0,
        "end_sec": 20.0,
        "tone": "warm_delighted"
      },
      {
        "beat_id": "b05",
        "text": "여행 중 쉬어가고 싶은 곳, 시선을 즐기다에서 직접 느껴보세요.",
        "start_sec": 20.0,
        "end_sec": 24.0,
        "tone": "gentle_closing"
      }
    ],
    "subtitle_mode": "burned_in",
    "subtitle_style": "clean_bottom"
  },
