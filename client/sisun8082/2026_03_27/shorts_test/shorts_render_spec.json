  "text_overlays": [
    {
      "text_id": "t01",
      "kind": "hook",
      "text": "필리핀 손님 5명이 한국 오기 전부터 예약한 이유",
      "start_sec": 0.0,
      "end_sec": 2.8,
      "position": "center",
      "style_preset": "hook_bold",
      "animation_in": "fade_up",
      "animation_out": "fade_out"
    },
    {
      "text_id": "t02",
      "kind": "supporting",
      "text": "도착하자마자 두피 진단부터",
      "start_sec": 3.2,
      "end_sec": 5.8,
      "position": "top_center",
      "style_preset": "label_minimal",
      "animation_in": "fade_in",
      "animation_out": "fade_out"
    },
    {
      "text_id": "t03",
      "kind": "supporting",
      "text": "5명 동시 케어 가능한 공간",
      "start_sec": 5.8,
      "end_sec": 8.2,
      "position": "bottom_center",
      "style_preset": "supporting_soft",
      "animation_in": "slide_up",
      "animation_out": "fade_out"
    },
    {
      "text_id": "t04",
      "kind": "supporting",
      "text": "스팀캡 + LED + 맞춤 케어",
      "start_sec": 8.2,
      "end_sec": 13.0,
      "position": "bottom_center",
      "style_preset": "supporting_soft",
      "animation_in": "fade_in",
      "animation_out": "fade_out"
    },
    {
      "text_id": "t05",
      "kind": "quote",
      "text": "\"K-뷰티는 최고다\"",
      "start_sec": 13.2,
      "end_sec": 15.6,
      "position": "center",
      "style_preset": "quote_soft",
      "animation_in": "fade_up",
      "animation_out": "fade_out"
    },
    {
      "text_id": "t06",
      "kind": "quote",
      "text": "\"너무 시원하다\"",
      "start_sec": 15.8,
      "end_sec": 18.8,
      "position": "center",
      "style_preset": "quote_soft",
      "animation_in": "fade_up",
      "animation_out": "fade_out"
    },
    {
      "text_id": "t07",
      "kind": "cta",
      "text": "부산 여행 중 서면에서 쉬어가기 좋은 헤드스파",
      "start_sec": 19.0,
      "end_sec": 23.4,
      "position": "bottom_center",
      "style_preset": "cta_clean",
      "animation_in": "slide_up",
      "animation_out": "fade_out"
    }
  ],
  "voiceover": {
    "mode": "tts",
    "script_blocks": [
      {
        "beat_id": "b01",
        "text": "필리핀에서 온 다섯 분이 한국 오기 전부터 예약하고 찾아온 서면 헤드스파.",
        "start_sec": 0.0,
        "end_sec": 3.2,
        "tone": "curious_warm"
      },
      {
        "beat_id": "b02",
        "text": "도착하자마자 두피 진단을 받고, 상태에 맞는 코스를 추천받습니다.",
        "start_sec": 3.2,
        "end_sec": 5.8,
        "tone": "clear_explanatory"
      },
      {
        "beat_id": "b03",
        "text": "다섯 명이 함께 케어를 받고, 스팀캡과 LED 테라피까지 이어집니다.",
        "start_sec": 5.8,
        "end_sec": 13.0,
        "tone": "steady_proof"
      },
      {
        "beat_id": "b04",
        "text": "받아보신 뒤엔 K뷰티 최고, 너무 시원하다는 반응이 바로 나왔어요.",
        "start_sec": 13.0,
        "end_sec": 18.8,
        "tone": "warm_reaction"
      },
      {
        "beat_id": "b05",
        "text": "부산 여행 중 서면에서 쉬어가고 싶다면, 시선을 즐기다에서 직접 느껴보세요.",
        "start_sec": 18.8,
        "end_sec": 23.4,
        "tone": "soft_cta"
      }
    ],
    "subtitle_mode": "burned_in",
    "subtitle_style": "clean_bottom"
  },
